{
  "name": "SmartNotes",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android:dev": "ENVFILE=.env.dev npx react-native run-android --mode=devDebug",
    "android:prod": "ENVFILE=.env.prod npx react-native run-android --mode=prodDebug",
    "android:dev:release": "ENVFILE=.env.dev cd android && ./gradlew assembleDevRelease",
    "android:prod:release": "ENVFILE=.env.prod cd android && ./gradlew assembleProdRelease",
    "airpush:android:release": "dotenv -e .env.prod -- sh -c 'npx appsairpush release --app \"$APPS_AIRPUSH_APP_ID\" --licenseKey \"$APPS_AIRPUSH_LICENSE_KEY\" --platform android'",
    "airpush:ios:release": "ENVFILE=.env.prod npx dotenv -- appsairpush release --app $APPS_AIRPUSH_APP_ID --licenseKey $APPS_AIRPUSH_LICENSE_KEY --platform ios --description \"$npm_config_desc\"",
    "airpush:android:rollback": "ENVFILE=.env.prod dotenv -- appsairpush rollback --app $APPS_AIRPUSH_APP_ID --licenseKey $APPS_AIRPUSH_LICENSE_KEY --platform android --description \"$npm_config_desc\"",
    "airpush:ios:rollback": "ENVFILE=.env.prod dotenv -- appsairpush rollback --app $APPS_AIRPUSH_APP_ID --licenseKey $APPS_AIRPUSH_LICENSE_KEY --platform ios --description \"$npm_config_desc\"",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native-documents/viewer": "^4.0.0",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "appsairpush-react-native": "^0.1.13",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-actions-sheet": "^10.1.2",
    "react-native-biometrics": "^3.0.1",
    "react-native-blob-util": "^0.24.7",
    "react-native-bootsplash": "^7.1.0",
    "react-native-config": "^1.6.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-haptic-feedback": "^2.3.4",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-pdf": "^7.0.4",
    "react-native-reanimated": "^4.3.0",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "^0.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
